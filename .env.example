# ─── Supabase ────────────────────────────────────────────────────────────────
# Supabase project URL (Settings → API → Project URL)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Supabase anon/public key (Settings → API → anon public)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Optional: Supabase service-role key (server-only, never expose to client) ─
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Coolify ──────────────────────────────────────────────────────────────────
# These are automatically injected by Coolify during build.
# Add them in Coolify → Application → Environment Variables.
# Build args in Dockerfile pass them to the Next.js build step.
